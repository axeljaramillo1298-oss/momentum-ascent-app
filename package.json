{
  "name": "fitnesapk",
  "version": "1.0.0",
  "private": true,
  "description": "APK wrapper for Fitnespag using Capacitor",
  "scripts": {
    "start": "node backend/server.js",
    "backend": "node backend/server.js",
    "backend:dev": "node --watch backend/server.js",
    "backend:sqlite": "set DB_CLIENT=sqlite&& node backend/server.js",
    "sync": "npx cap sync",
    "android": "npx cap open android",
    "copy": "npx cap copy"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2"
  }
}
